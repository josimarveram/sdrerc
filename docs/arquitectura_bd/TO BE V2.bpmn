  <process id="Id_d88ac455-ec56-4f21-b60d-8744cb85a959">
    <documentation />
    <laneSet id="Id_3bca87ff-2ce9-4fdc-85e6-d7e8d84e5efd">
      <lane id="Id_33e71779-9293-40fc-b291-6ceee9a752e7" name="OGD">
        <documentation />
        <childLaneSet id="Id_04d4ed5c-d812-41dc-b4ed-742678b849c1" />
      </lane>
      <lane id="Id_4bd340ca-bd58-4b91-8654-1075dc5ebddb" name="SUB DIRECTOR DE SDRERC">
        <documentation />
        <childLaneSet id="Id_d1d98495-9fea-402c-8a47-1911d5b2be55" />
      </lane>
      <lane id="Id_dbf9f9c0-8ede-487d-aec8-fe35e400199b" name="ASISTENTE DE RECPCIÓN">
        <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Segoe UI;font-size:8pt;font-weight:normal;font-style:normal;"&gt;realizara el registro de los documentos recibidos y el sistema arrojara una alerta de las solicitudes que son duplicadas&lt;/span&gt;&lt;/p&gt;</documentation>
        <childLaneSet id="Id_71aa77a2-6a3b-48e0-a8be-e26c10d4bfc3" />
      </lane>
      <lane id="Id_059de830-de0e-4df1-9d86-e92cafb540d3" name="ASIGNADOR">
        <documentation>&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Segoe UI;font-size:8pt;font-weight:normal;font-style:normal;"&gt;se encargara de validar las bandejas de los abogados, validará y asociará las solicitudes duplicadas o los documentos (carta); asignara los expedientes segun tipo de solicitud.&lt;/span&gt;&lt;/p&gt;&lt;p style="text-align:left;text-indent:0pt;margin:0pt 0pt 0pt 0pt;"&gt;&lt;span style="color:#000000;background-color:transparent;font-family:Segoe UI;font-size:8pt;font-weight:normal;font-style:normal;"&gt;tendra la opcion de reasignar los expedientes en cualquier tipo de situación&lt;/span&gt;&lt;/p&gt;</documentation>
        <childLaneSet id="Id_143f6565-b073-4ae3-b9c9-6896ea44b1ad" />
      </lane>
      <lane id="Id_58844a14-91f5-422a-847b-63a32e4c40c8" name="SUPERVISOR">
        <documentation />
        <childLaneSet id="Id_60f21ff8-bea1-4ba7-8d6e-5404040c3d6a" />
      </lane>
      <lane id="Id_d3a75435-0813-4f65-803d-50ff92779e00" name="ABOGADO">
        <documentation />
        <childLaneSet id="Id_7ecf3513-c7ce-4a93-8d12-0a3dd8eb4b74" />
      </lane>
      <lane id="Id_01acb731-c43e-4b59-90ed-5834921206ff" name="SDPRC">
        <documentation />
        <childLaneSet id="Id_5ddb2b90-681b-46a8-9bf4-9ca2cf1df207" />
      </lane>
    </laneSet>
